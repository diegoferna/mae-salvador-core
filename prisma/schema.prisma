generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("APP_DATABASE_URL")
}

model Usuario {
  id         String         @id @default(uuid())
  tipo       String
  cpf        String?
  cns        String?
  senhaHash  String?        @map("senha_hash")
  status     String
  gestante   Gestante?
  papeis     UsuarioPapel[]
  sessoes    Sessao[]

  @@map("usuario")
}

model Pessoa {
  id        String     @id @default(uuid())
  nome      String     @map("nome_completo")
  nomeSocial String?   @map("nome_social")
  nomeMae   String?    @map("nome_mae")
  nomePai   String?    @map("nome_pai")
  dataNascimento DateTime? @map("data_nascimento")
  racaCor   String?    @map("raca_cor")
  sexo      String?
  identidadeGenero String? @map("identidade_genero")
  orientacaoSexual String? @map("orientacao_sexual")
  email     String?
  nis       String?
  gestante  Gestante?
  enderecos Endereco[]

  @@map("pessoa")
}

model Gestante {
  id             String   @id @default(uuid())
  usuarioId      String   @unique @map("usuario_id")
  pessoaId       String   @unique @map("pessoa_id")
  origemCadastro String   @map("origem_cadastro")
  status         String
  possuiDeficiencia Boolean? @map("possui_deficiencia")
  planoSaudeParticular Boolean? @map("plano_saude_particular")
  alergiasConhecidas Boolean? @map("alergias_conhecidas")
  medicamentosEmUso Boolean? @map("medicamentos_em_uso")
  doencasPreexistentes Boolean? @map("doencas_preexistentes")
  cadastroAtualizadoEm DateTime? @map("cadastro_atualizado_em")
  usuario        Usuario  @relation(fields: [usuarioId], references: [id])
  pessoa         Pessoa   @relation(fields: [pessoaId], references: [id])
  vinculo        GestanteVinculo?
  escolhas       GestanteUnidadeEscolha[]
  contato        GestanteContato?
  deficiencias   GestanteDeficiencia[]
  programasSociais GestanteProgramaSocial[]

  @@map("gestante")
}

model UsuarioPapel {
  id         String  @id @default(uuid())
  usuarioId  String  @map("usuario_id")
  papel      String
  ubsId      String? @map("ubs_id")
  distritoId String? @map("distrito_id")
  ativo      Boolean
  usuario    Usuario @relation(fields: [usuarioId], references: [id])

  @@map("usuario_papel")
}

model Ubs {
  id       String @id @default(uuid())
  codigo   String
  nome     String
  cnes     String?
  tipo     String

  @@map("ubs")
}

model Sessao {
  id         String   @id @default(uuid())
  usuarioId  String   @map("usuario_id")
  tokenHash  String   @unique @map("token_hash")
  refreshHash String? @map("refresh_hash")
  origem     String
  expiracao  DateTime
  revogadaEm DateTime? @map("revogada_em")
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("sessao")
}

model GestanteVinculo {
  gestanteId String @id @map("gestante_id")
  ubsId      String @map("ubs_id")
  gestante   Gestante @relation(fields: [gestanteId], references: [id])

  @@map("gestante_vinculo")
}

model GestanteUnidadeEscolha {
  id                     String   @id @default(uuid())
  gestanteId             String   @map("gestante_id")
  ubsId                  String?  @map("ubs_id")
  unidadeEscolhidaNome   String   @map("unidade_escolhida_nome")
  unidadeEscolhidaOrigem String   @map("unidade_escolhida_origem")
  criadoEm               DateTime @default(now()) @map("criado_em")
  gestante               Gestante @relation(fields: [gestanteId], references: [id])

  @@map("gestante_unidade_escolha")
}

model GestanteEsqueceuSenhaTentativas {
  cpfCns            String   @id @map("cpf_cns")
  tentativas        Int
  bloqueadoAte      DateTime? @map("bloqueado_ate")
  ultimoDesafioHash String?  @map("ultimo_desafio_hash")
  atualizadoEm      DateTime @default(now()) @map("atualizado_em")

  @@map("gestante_esqueceu_senha_tentativas")
}

model Endereco {
  id                  String  @id @default(uuid())
  pessoaId            String  @map("pessoa_id")
  cep                 String?
  logradouro          String?
  tipoLogradouro      String? @map("tipo_logradouro")
  numero              String?
  complemento         String?
  bairro              String?
  municipio           String?
  pontoReferencia     String? @map("ponto_referencia")
  distritoSanitarioId String? @map("distrito_sanitario_id")
  pessoa              Pessoa  @relation(fields: [pessoaId], references: [id])

  @@map("endereco")
}

model GestanteContato {
  id                       String   @id @default(uuid())
  gestanteId               String   @unique @map("gestante_id")
  dddCelularPrincipal      String?  @map("ddd_celular_principal")
  celularPrincipal         String?  @map("celular_principal")
  celularPrincipalWhatsapp Boolean? @map("celular_principal_whatsapp")
  dddCelularAlternativo    String?  @map("ddd_celular_alternativo")
  celularAlternativo       String?  @map("celular_alternativo")
  celularAlternativoWhatsapp Boolean? @map("celular_alternativo_whatsapp")
  dddResidencial           String?  @map("ddd_residencial")
  telefoneResidencial      String?  @map("telefone_residencial")
  gestante                 Gestante @relation(fields: [gestanteId], references: [id])

  @@map("gestante_contato")
}

model GestanteDeficiencia {
  id         String   @id @default(uuid())
  gestanteId String   @map("gestante_id")
  tipo       String
  criadoEm   DateTime @default(now()) @map("criado_em")
  gestante   Gestante @relation(fields: [gestanteId], references: [id])

  @@map("gestante_deficiencia")
}

model GestanteProgramaSocial {
  id            String   @id @default(uuid())
  gestanteId    String   @map("gestante_id")
  programaCodigo String  @map("programa_codigo")
  programaNome  String   @map("programa_nome")
  criadoEm      DateTime @default(now()) @map("criado_em")
  gestante      Gestante @relation(fields: [gestanteId], references: [id])

  @@map("gestante_programa_social")
}
